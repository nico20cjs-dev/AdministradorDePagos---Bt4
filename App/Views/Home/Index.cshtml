@{ Layout = null; }
<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Panel para gestionar y analizar comprobantes de pago de forma rapida y segura.">
    <meta name="robots" content="index,follow">
    <meta name="theme-color" content="#0f172a">
    <title>Administrador de Pagos</title>

    @Styles.Render("~/bundles/appcss")
</head>
<body>
    <main class="app-shell">
        <header class="topbar" aria-label="Encabezado principal">
            <div>
                <h1 class="app-title">Administrador de Pagos</h1>
                <p class="app-subtitle">Control centralizado de comprobantes, filtros y totales.</p>
            </div>
            <div class="topbar-actions">
                <button id="themeToggle" class="btn btn-ghost" type="button" aria-pressed="false">Modo oscuro</button>
                <button id="btnActualizarPdf" class="btn btn-primary" type="button">Actualizar pagos</button>
            </div>
        </header>

        <section class="stats-grid" aria-label="Resumenes">
            <article class="stat-card">
                <p class="stat-label">Total en Pesos</p>
                <p id="pesosCalculados" class="stat-value">$ 0,00</p>
            </article>
            <article class="stat-card">
                <p class="stat-label">Total en Dolares</p>
                <p id="dolaresCalculados" class="stat-value">USD 0.00</p>
            </article>
        </section>

        <section class="toolbar" aria-label="Herramientas de vista">
            <div class="toolbar-left">
                <button id="btnToggleFiltros" class="btn btn-secondary" type="button" aria-expanded="false" aria-controls="filtersPanel">Mostrar filtros</button>
                <span id="loadState" class="load-state" aria-live="polite">Listo</span>
            </div>
            <div id="div1" class="hourglass" aria-hidden="true"></div>
        </section>

        <section id="contentMensajes" class="message-grid" aria-live="polite"></section>

        <section id="filtersPanel" class="filters-panel is-collapsed" aria-label="Filtros de busqueda">
            <div class="filters-grid">
                <label class="field">
                    <span>Importe desde</span>
                    <input type="number" id="ImporteDesde" placeholder="0" min="0" step="0.01">
                </label>
                <label class="field">
                    <span>Importe hasta</span>
                    <input type="number" id="ImporteHasta" placeholder="0" min="0" step="0.01">
                </label>
                <label class="field">
                    <span>Referencia</span>
                    <select id="selectReference">
                        <option value=""></option>
                        <option value="0">-</option>
                        <option value="1">Yrigoyen</option>
                        <option value="2">Nico</option>
                        <option value="3">Norma</option>
                        <option value="4">Tia Raquel</option>
                        <option value="5">Velez Sarsfield</option>
                        <option value="6">Villa Gesell</option>
                    </select>
                </label>
                <label class="field field-wide">
                    <span>Ente</span>
                    <select id="selectEnte">
                        <option value=""></option>
                        <option value="Arba">Arba</option>
                        <option value="Aguas Bonaerenses">(Agua) Aguas Bonaerenses</option>
                        <option value="Agua y Saneamientos Argentinos">(Agua) AySA</option>
                        <option value="Edesur">(Luz) Edesur</option>
                        <option value="Cevige">(Luz) Cevige</option>
                        <option value="Metrogas">(Gas) Metrogas</option>
                        <option value="Municipalidad de Lanus">(Municipal) Lanus</option>
                        <option value="Municipalidad de Villa Gesell">(Municipal) Villa Gesell</option>
                        <option value="Claro">(Telefonia) Claro</option>
                        <option value="Movistar">(Telefonia) Movistar</option>
                    </select>
                </label>
            </div>
            <div class="filters-actions">
                <button id="btnAplicarFiltros" class="btn btn-primary" type="button">Aplicar</button>
                <button id="btnLimpiarFiltros" class="btn btn-ghost" type="button">Limpiar</button>
            </div>
        </section>

        <section class="table-section" aria-label="Listado de pagos">
            <div id="showHiddenCol" class="column-toggle">
                <span>Columnas:</span>
                <button class="toggle-vis" data-column="0" type="button">Nro Transaccion</button>
                <button class="toggle-vis" data-column="1" type="button">Ente</button>
                <button class="toggle-vis" data-column="2" type="button">N Cliente</button>
                <button class="toggle-vis" data-column="3" type="button">N CtaDebito</button>
                <button class="toggle-vis" data-column="4" type="button">Fecha Vto</button>
                <button class="toggle-vis" data-column="5" type="button">Cuota</button>
                <button class="toggle-vis" data-column="6" type="button">PDF</button>
                <button class="toggle-vis" data-column="7" type="button">Tipo Comp</button>
                <button class="toggle-vis" data-column="10" type="button">Importe USD</button>
                <button class="toggle-vis" data-column="11" type="button">Referencia</button>
            </div>

            <div class="table-wrap">
                <table id="dataTable" class="display compact" width="100%">
                    <thead>
                        <tr>
                            <th>Nro Transaccion</th>
                            <th>Ente</th>
                            <th>N Cliente</th>
                            <th>N CtaDebito</th>
                            <th>Fecha Vto</th>
                            <th>Cuota</th>
                            <th>PDF</th>
                            <th>Tipo Comp</th>
                            <th>Fecha Pago</th>
                            <th>Importe $</th>
                            <th>Importe USD</th>
                            <th>Referencia</th>
                        </tr>
                    </thead>
                    <tbody id="contenTabla"></tbody>
                    <tfoot>
                        <tr>
                            <th>Nro Transaccion</th>
                            <th>Ente</th>
                            <th>N Cliente</th>
                            <th>N CtaDebito</th>
                            <th>Fecha Vto</th>
                            <th>Cuota</th>
                            <th>PDF</th>
                            <th>Tipo Comp</th>
                            <th>Fecha Pago</th>
                            <th>Importe $</th>
                            <th>Importe USD</th>
                            <th>Referencia</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </section>
    </main>

    @Scripts.Render("~/bundles/appscripts")

    <script>
        var table = null;
        var colPath = -1;

        function parseMvcDate(value) {
            if (!value) {
                return '';
            }
            var ticks = value.toString().replace('/Date(', '').replace(')/', '');
            var date = new Date(parseInt(ticks, 10));
            if (isNaN(date.getTime())) {
                return '';
            }
            return date.yyyymmdd();
        }

        function formatArs(value) {
            return new Intl.NumberFormat('es-AR', { style: 'currency', currency: 'ARS', minimumFractionDigits: 2 }).format(value || 0);
        }

        function formatUsd(value) {
            return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2 }).format(value || 0);
        }

        function setLoading(isLoading) {
            var button = $('#btnActualizarPdf');
            var state = $('#loadState');
            if (isLoading) {
                button.prop('disabled', true).text('Actualizando...');
                state.text('Procesando comprobantes...');
            } else {
                button.prop('disabled', false).text('Actualizar pagos');
                state.text('Listo');
            }
        }

        function setTheme(theme) {
            document.documentElement.setAttribute('data-theme', theme);
            localStorage.setItem('adp-theme', theme);
            var isDark = theme === 'dark';
            $('#themeToggle').attr('aria-pressed', isDark ? 'true' : 'false').text(isDark ? 'Modo claro' : 'Modo oscuro');
        }

        function initTheme() {
            var stored = localStorage.getItem('adp-theme');
            if (stored === 'dark' || stored === 'light') {
                setTheme(stored);
                return;
            }
            var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
            setTheme(prefersDark ? 'dark' : 'light');
        }

        function reiniciarVariablesGrales() {
            colPath = -1;
        }

        function getStringReference(nroRerence) {
            var nro = typeof nroRerence === 'string' ? parseInt(nroRerence, 10) : nroRerence;
            switch (nro) {
                case 0: return '-';
                case 1: return 'Yrigoyen';
                case 2: return 'Nico';
                case 3: return 'Norma';
                case 4: return 'Tia Raquel';
                case 5: return 'Velez Sarsfield';
                case 6: return 'Villa Gesell';
                default: return '-';
            }
        }

        function totalizarPagos() {
            var dt = $('#dataTable').dataTable().api();
            var rows = dt.rows({ search: 'applied' }).data();
            var totalPesos = 0;
            var totalDolares = 0;

            rows.each(function (item) {
                totalPesos += Number(item[9]) || 0;
                totalDolares += Number(item[10]) || 0;
            });

            $('#pesosCalculados').text(formatArs(totalPesos));
            $('#dolaresCalculados').text(formatUsd(totalDolares));
        }

        function leerPdf(action) {
            var endpoint = action || 'LeerPDF';
            reiniciarVariablesGrales();
            setLoading(true);
            limpiarMensajes();

            $('#dataTable').DataTable().rows().remove().draw(false);

            $.ajax({
                url: 'Home/' + endpoint + '/',
                success: function (respuesta) {
                    var lstMsj = respuesta.Mensajes.Lista;
                    if (lstMsj.length > 0) {
                        procesarMensajes(lstMsj);
                        return;
                    }

                    var t = $('#dataTable').DataTable();
                    t.rows().remove().draw(false);

                    respuesta.pagos.forEach(function (pago) {
                        t.row.add([
                            pago.NroTransaccion,
                            pago.Ente,
                            pago.NroCliente,
                            pago.NroCtaDebito,
                            parseMvcDate(pago.FechaVencimiento),
                            pago.Cuota,
                            '<button type="button" class="pdf-link" data-path="' + pago.Path + '">Abrir</button>',
                            pago.TipoComprobante,
                            parseMvcDate(pago.FechaPago),
                            Number(pago.Importe) || 0,
                            Number(pago.ImporteDolar) || 0,
                            getStringReference(pago.Referencia)
                        ]).draw(true);
                    });

                    callBackLeerPdf();
                },
                error: function (err) {
                    procesarMensajes([{ Tipo: 0, Texto: 'No se pudo actualizar la informacion. Estado: ' + err.status }]);
                },
                complete: function () {
                    setLoading(false);
                }
            });
        }

        function callBackLeerPdf() {
            var dt = $('#dataTable').DataTable();
            dt.columns.adjust().draw(false);
            totalizarPagos();
        }

        function applyAdvancedFilters() {
            table.draw();
            totalizarPagos();
        }

        $(document).ready(function () {
            initTheme();

            $('#themeToggle').on('click', function () {
                var current = document.documentElement.getAttribute('data-theme');
                setTheme(current === 'dark' ? 'light' : 'dark');
            });

            $('#btnToggleFiltros').on('click', function () {
                var panel = $('#filtersPanel');
                var isCollapsed = panel.hasClass('is-collapsed');
                panel.toggleClass('is-collapsed', !isCollapsed);
                $(this).attr('aria-expanded', isCollapsed ? 'true' : 'false').text(isCollapsed ? 'Ocultar filtros' : 'Mostrar filtros');
            });

            $('#btnAplicarFiltros').on('click', applyAdvancedFilters);
            $('#btnLimpiarFiltros').on('click', function () {
                $('#ImporteDesde').val('');
                $('#ImporteHasta').val('');
                $('#selectReference').val('');
                $('#selectEnte').val('');
                applyAdvancedFilters();
            });

            $('#btnActualizarPdf').on('click', function () {
                leerPdf('ActualizarPDF');
            });

            $('#dataTable tfoot th').each(function () {
                var title = $(this).text();
                $(this).html('<input type="text" placeholder="Buscar ' + title + '" />');
            });

            table = $('#dataTable').DataTable({
                createdRow: function (row) {
                    if (colPath === -1) {
                        for (var i = 0; i < row.cells.length; i++) {
                            if (row.cells[i].innerHTML.indexOf('data-path') > -1) {
                                colPath = i;
                                break;
                            }
                        }
                    }

                    if (colPath > -1) {
                        $($('td', row)[colPath]).addClass('pointer').on('click', function () {
                            var ruta = $(this).find('.pdf-link').data('path');
                            if (ruta) {
                                window.open('/Home/GetReport?path=' + encodeURIComponent(ruta), '_blank');
                            }
                        });
                    }
                },
                aoColumnDefs: [
                    { bSortable: false, aTargets: [6] },
                    { sWidth: '120px', aTargets: [4, 8, 9, 10] }
                ],
                bAutoWidth: false,
                orderCellsTop: true,
                language: {
                    search: 'Buscar:',
                    info: 'Mostrando _START_ a _END_ de _TOTAL_ pagos',
                    infoEmpty: 'Sin pagos disponibles',
                    lengthMenu: 'Mostrar _MENU_ pagos',
                    paginate: {
                        previous: 'Anterior',
                        next: 'Siguiente'
                    }
                },
                initComplete: function () {
                    this.api().columns().every(function () {
                        var that = this;
                        $('input', this.footer()).on('keyup change clear', function () {
                            if (that.search() !== this.value) {
                                that.search(this.value).draw();
                                totalizarPagos();
                            }
                        });
                    });
                }
            });

            table.columns([0, 2, 3, 5, 7]).visible(false, false);
            table.columns.adjust().draw(false);

            $('button.toggle-vis').on('click', function () {
                var column = table.column($(this).attr('data-column'));
                column.visible(!column.visible());
            });

            $.fn.dataTable.ext.search.push(function (settings, data) {
                if (settings.nTable.id !== 'dataTable') {
                    return true;
                }

                var min = parseFloat($('#ImporteDesde').val());
                var max = parseFloat($('#ImporteHasta').val());
                var importe = parseFloat(data[9]) || 0;

                if (!isNaN(min) && importe < min) {
                    return false;
                }
                if (!isNaN(max) && importe > max) {
                    return false;
                }

                var selectReference = $('#selectReference').val();
                if (selectReference !== '') {
                    var txtReference = getStringReference(selectReference);
                    if ((data[11] || '').toString() !== txtReference) {
                        return false;
                    }
                }

                var selectEnte = ($('#selectEnte').val() || '').toLowerCase();
                if (selectEnte !== '') {
                    var enteDT = (data[1] || '').toLowerCase();
                    if (enteDT.indexOf(selectEnte) === -1) {
                        return false;
                    }
                }

                return true;
            });

            leerPdf();
        });
    </script>
</body>
</html>
