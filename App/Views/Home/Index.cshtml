@{ Layout = null; }
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Panel para gestionar y analizar comprobantes de pago de forma rapida y segura.">
    <meta name="robots" content="index,follow">
    <meta name="theme-color" content="#0f172a">
    <title>Administrador de Pagos</title>
    <script>
        (function () {
            var t = localStorage.getItem('adp-theme');
            if (t !== 'dark' && t !== 'light') t = 'dark';
            document.documentElement.setAttribute('data-theme', t);
            if (t === 'dark') document.querySelector('meta[name=theme-color]').content = '#0b1220';
        })();
    </script>

    @Styles.Render("~/bundles/appcss")
</head>
<body>
    <main class="app-shell">
        <header class="topbar" aria-label="Encabezado principal">
            <div>
                <h1 class="app-title">Administrador de Pagos</h1>
                <p class="app-subtitle">Control centralizado de comprobantes, filtros y totales.</p>
            </div>
            <div class="topbar-actions">
                <button id="themeToggle" class="btn btn-ghost" type="button" aria-pressed="false">
                    <svg class="btn-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="currentColor" d="M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36a5.39 5.39 0 0 1-4.4 2.26 5.38 5.38 0 0 1-5.38-5.38 5.39 5.39 0 0 1 2.26-4.4A9.05 9.05 0 0 0 12 3Z"/></svg>
                    <span>Modo oscuro</span>
                </button>
                <button id="btnActualizarPdf" class="btn btn-primary" type="button">
                    <svg class="btn-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M1 4v6h6m16 10v-6h-6M3.51 15a9 9 0 0 0 14.85 3.36l-2.12-2.12a5.5 5.5 0 0 1-8.37-.74M20.49 9a9 9 0 0 0-14.85-3.36l2.12 2.12a5.5 5.5 0 0 1 8.37.74"/></svg>
                    <span>Actualizar pagos</span>
                </button>
            </div>
        </header>

        <section class="stats-grid" aria-label="Resumenes">
            <article class="stat-card">
                <p class="stat-label">Total en Pesos</p>
                <p id="pesosCalculados" class="stat-value">$ 0,00</p>
            </article>
            <article class="stat-card">
                <p class="stat-label">Total en Dolares</p>
                <p id="dolaresCalculados" class="stat-value">USD 0.00</p>
            </article>
            <article class="stat-card stat-card-warn">
                <p class="stat-label">No procesados</p>
                <p id="noProcesados" class="stat-value">0</p>
                <button id="btnDetalleFallos" class="stat-action" type="button" title="Ver detalle de archivos no procesados">
                    <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M8 6h8M8 12h8m-8 6h5"/><rect x="3" y="3" width="18" height="18" rx="2" fill="none" stroke="currentColor" stroke-width="2"/></svg>
                    Detalle
                </button>
            </article>
        </section>

        <section class="toolbar" aria-label="Herramientas de vista">
            <div class="toolbar-left">
                <button id="btnToggleFiltros" class="btn btn-secondary" type="button" aria-expanded="false" aria-controls="filtersPanel">
                    <svg class="btn-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M4 21v-7m0-4V3m8 18v-9m0-4V3m8 18v-5m0-4V3M1 14h6m2-6h6m2 8h6"/></svg>
                    <span>Mostrar filtros</span>
                </button>
                <span id="loadState" class="load-state" aria-live="polite">Listo</span>
                <div id="loadSpinner" class="spinner" aria-hidden="true"></div>
            </div>
        </section>

        <section id="contentMensajes" class="message-grid" aria-live="polite"></section>

        <section id="filtersPanel" class="filters-panel is-collapsed" aria-label="Filtros de busqueda">
            <div class="filters-grid">
                <label class="field">
                    <span>Importe desde</span>
                    <input type="number" id="ImporteDesde" placeholder="0" min="0" step="0.01">
                </label>
                <label class="field">
                    <span>Importe hasta</span>
                    <input type="number" id="ImporteHasta" placeholder="0" min="0" step="0.01">
                </label>
                <label class="field">
                    <span>Referencia</span>
                    <select id="selectReference">
                        <option value=""></option>
                        <option value="0">-</option>
                        <option value="1">Yrigoyen</option>
                        <option value="2">Nico</option>
                        <option value="3">Norma</option>
                        <option value="4">Tia Raquel</option>
                        <option value="5">Velez Sarsfield</option>
                        <option value="6">Villa Gesell</option>
                    </select>
                </label>
                <label class="field field-wide">
                    <span>Ente</span>
                    <select id="selectEnte">
                        <option value=""></option>
                        <option value="Arba">Arba</option>
                        <option value="Aguas Bonaerenses">(Agua) Aguas Bonaerenses</option>
                        <option value="Agua y Saneamientos Argentinos">(Agua) AySA</option>
                        <option value="Edesur">(Luz) Edesur</option>
                        <option value="Cevige">(Luz) Cevige</option>
                        <option value="Metrogas">(Gas) Metrogas</option>
                        <option value="Municipalidad de Lanus">(Municipal) Lanus</option>
                        <option value="Municipalidad de Villa Gesell">(Municipal) Villa Gesell</option>
                        <option value="Claro">(Telefonia) Claro</option>
                        <option value="Movistar">(Telefonia) Movistar</option>
                    </select>
                </label>
            </div>
            <div class="filters-actions">
                <button id="btnAplicarFiltros" class="btn btn-primary" type="button">
                    <svg class="btn-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="m5 13 4 4L19 7"/></svg>
                    <span>Aplicar</span>
                </button>
                <button id="btnLimpiarFiltros" class="btn btn-ghost" type="button">
                    <svg class="btn-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M18 6 6 18M6 6l12 12"/></svg>
                    <span>Limpiar</span>
                </button>
            </div>
        </section>

        <section class="table-section" aria-label="Listado de pagos">
            <div id="showHiddenCol" class="column-toggle">
                <span>Columnas:</span>
                <button class="toggle-vis" data-column="0" type="button">Nro Transaccion</button>
                <button class="toggle-vis" data-column="1" type="button">Ente</button>
                <button class="toggle-vis" data-column="2" type="button">Nº Cliente</button>
                <button class="toggle-vis" data-column="3" type="button">Nº CtaDebito</button>
                <button class="toggle-vis" data-column="4" type="button">Fecha Vto</button>
                <button class="toggle-vis" data-column="5" type="button">Cuota</button>
                <button class="toggle-vis" data-column="6" type="button">PDF</button>
                <button class="toggle-vis" data-column="7" type="button">Tipo Comp</button>
                <button class="toggle-vis" data-column="10" type="button">Importe USD</button>
                <button class="toggle-vis" data-column="11" type="button">Referencia</button>
            </div>

            <div class="table-wrap">
                <table id="dataTable" class="display compact" width="100%">
                    <thead>
                        <tr>
                            <th>Nro Transaccion</th>
                            <th>Ente</th>
                            <th>Nº Cliente</th>
                            <th>Nº CtaDebito</th>
                            <th>Fecha Vto</th>
                            <th>Cuota</th>
                            <th>PDF</th>
                            <th>Tipo Comp</th>
                            <th>Fecha Pago</th>
                            <th>Importe $</th>
                            <th>Importe USD</th>
                            <th>Referencia</th>
                        </tr>
                    </thead>
                    <tbody id="contenTabla"></tbody>
                    <tfoot>
                        <tr>
                            <th>Nro Transaccion</th>
                            <th>Ente</th>
                            <th>Nº Cliente</th>
                            <th>Nº CtaDebito</th>
                            <th>Fecha Vto</th>
                            <th>Cuota</th>
                            <th>PDF</th>
                            <th>Tipo Comp</th>
                            <th>Fecha Pago</th>
                            <th>Importe $</th>
                            <th>Importe USD</th>
                            <th>Referencia</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </section>
    </main>

    <div id="modalFallos" class="modal-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Archivos no procesados">
        <div class="modal-panel">
            <header class="modal-header">
                <h2>PDFs no procesados</h2>
                <button id="modalFallosCerrar" class="modal-close" type="button" aria-label="Cerrar">&times;</button>
            </header>
            <div id="modalFallosBody" class="modal-body"></div>
            <footer class="modal-footer">
                <span class="modal-hint">Hacé clic sobre un archivo para abrir su carpeta</span>
                <button id="modalFallosCerrarBtn" class="btn btn-ghost" type="button">Cerrar</button>
            </footer>
        </div>
    </div>

    @Scripts.Render("~/bundles/appscripts")

</body>
</html>
