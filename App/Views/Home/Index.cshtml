@{ Layout = null; }
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Panel para gestionar y analizar comprobantes de pago de forma rapida y segura.">
    <meta name="robots" content="index,follow">
    <meta name="theme-color" content="#0f172a">
    <title>Administrador de Pagos</title>
    <script>
        (function () {
            var t = localStorage.getItem('adp-theme');
            if (t !== 'dark' && t !== 'light') t = 'dark';
            document.documentElement.setAttribute('data-theme', t);
            if (t === 'dark') document.querySelector('meta[name=theme-color]').content = '#0b1220';

            var f = localStorage.getItem('adp-font');
            if (f !== 'large') f = 'normal';
            document.documentElement.setAttribute('data-font', f);
        })();
    </script>

    @Styles.Render("~/bundles/appcss")
</head>
<body>
    <main class="app-shell">
        <header class="topbar" aria-label="Encabezado principal">
            <div class="topbar-left">
                <button id="btnToggleFiltros" class="btn btn-secondary" type="button" aria-expanded="false" aria-controls="filtersPanel" title="Mostrar u ocultar el panel de filtros">
                    <svg class="btn-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M4 21v-7m0-4V3m8 18v-9m0-4V3m8 18v-5m0-4V3M1 14h6m2-6h6m2 8h6"/></svg>
                    <span>Mostrar filtros</span>
                </button>
                <span id="loadState" class="load-state" aria-live="polite">Listo</span>
                <div id="loadSpinner" class="spinner" aria-hidden="true"></div>
            </div>
            <div class="topbar-center">
                <h1 class="app-title">Administrador de Pagos</h1>
                <p class="app-subtitle">Control centralizado de comprobantes, filtros y totales.</p>
            </div>
            <div class="topbar-right">
                <button id="themeToggle" class="btn btn-ghost" type="button" aria-pressed="false" title="Alternar entre modo oscuro y claro">
                    <svg class="btn-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="currentColor" d="M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36a5.39 5.39 0 0 1-4.4 2.26 5.38 5.38 0 0 1-5.38-5.38 5.39 5.39 0 0 1 2.26-4.4A9.05 9.05 0 0 0 12 3Z"/></svg>
                    <span>Modo oscuro</span>
                </button>
                <button id="fontToggle" class="btn btn-ghost" type="button" aria-pressed="false" title="Cambiar tamaño de texto">
                    <svg class="btn-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><polyline points="4 7 4 4 20 4 20 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><line x1="9" y1="20" x2="15" y2="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="4" x2="12" y2="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    <span>Texto normal</span>
                </button>
                <button id="btnActualizarPdf" class="btn btn-primary" type="button" title="Actualizar la lista de pagos desde los comprobantes PDF">
                    <svg class="btn-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M1 4v6h6m16 10v-6h-6M3.51 15a9 9 0 0 0 14.85 3.36l-2.12-2.12a5.5 5.5 0 0 1-8.37-.74M20.49 9a9 9 0 0 0-14.85-3.36l2.12 2.12a5.5 5.5 0 0 1 8.37.74"/></svg>
                    <span>Actualizar pagos</span>
                </button>
            </div>
        </header>

        <section class="stats-grid" aria-label="Resumenes">
            <article class="stat-card">
                <p class="stat-label">Total en Pesos</p>
                <p id="pesosCalculados" class="stat-value">$ 0,00</p>
            </article>
            <article class="stat-card">
                <p class="stat-label">Total en Dolares</p>
                <p id="dolaresCalculados" class="stat-value">USD 0.00</p>
            </article>
            <article class="stat-card">
                <p class="stat-label">USD Actualizados
                    <button id="btnInfoUsdActualizado" class="info-btn" type="button" title="¿Qué significa USD Actualizados?">ⓘ</button>
                </p>
                <p id="dolaresActualizadosCalculados" class="stat-value-usd-actualizado">USD 0.00</p>
            </article>
            <article class="stat-card stat-card-warn">
                <p class="stat-label">No procesados</p>
                <p id="noProcesados" class="stat-value">0</p>
                <button id="btnDetalleFallos" class="stat-action" type="button" title="Ver detalle de archivos no procesados">
                    <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M8 6h8M8 12h8m-8 6h5"/><rect x="3" y="3" width="18" height="18" rx="2" fill="none" stroke="currentColor" stroke-width="2"/></svg>
                    Detalle
                </button>
            </article>
        </section>

        <section class="stats-grid-ref" aria-label="Totales por referencia"></section>

        <div class="app-layout">
            <aside id="filtersPanel" class="filters-sidebar is-collapsed" aria-label="Filtros de busqueda">
                <div class="filters-sidebar-inner">
                    <div class="filters-stack">
                        <label class="field">
                            <span>Referencia</span>
                            <select id="selectReference">
                                <option value=""></option>
                                <option value="0">-</option>
                                <option value="1">Yrigoyen</option>
                                <option value="2">Nico</option>
                                <option value="3">Norma</option>
                                <option value="4">Tia Raquel</option>
                                <option value="5">Tia Renee</option>
                                <option value="6">Velez Sarsfield</option>
                                <option value="7">Villa Gesell</option>
                            </select>
                        </label>
                        <label class="field">
                            <span>Ente</span>
                            <select id="selectEnte">
                                <option value=""></option>
                                <option value="0">Desconocido</option>
                                <option value="1">💰 Arba</option>
                                <option value="2">💧 Aguas Bonaerenses</option>
                                <option value="3">💧 AySA</option>
                                <option value="4">🏠 Expensas Lanus</option>
                                <option value="5">🏠 Ungar VG</option>
                                <option value="6">⚡ Edesur</option>
                                <option value="7">⚡ Cevige</option>
                                <option value="8">🔥 Metrogas</option>
                                <option value="9">🏛️ Municip. Lanus</option>
                                <option value="10">🏛️ Municip. Villa Gesell</option>
                                <option value="11">📞 Claro</option>
                                <option value="12">📞 Movistar</option>
                                <option value="13">📞 Telecentro</option>
                                <option value="14">📞 Telefonica</option>
                            </select>
                        </label>
                    </div>
                    <div class="filters-actions">
                        <button id="btnLimpiarFiltros" class="btn btn-ghost" type="button" title="Limpiar todos los filtros">
                            <svg class="btn-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M18 6 6 18M6 6l12 12"/></svg>
                            <span>Limpiar filtros</span>
                        </button>
                    </div>
                </div>
            </aside>
            <div class="app-main">
                <section id="contentMensajes" class="message-grid" aria-live="polite"></section>

                <section class="table-section" aria-label="Listado de pagos">
            <div id="showHiddenCol" class="column-toggle">
                <span>Columnas:</span>
                <button class="toggle-vis" data-column="0" type="button" title="Mostrar/ocultar Nro Transaccion">Nro Transaccion</button>
                <button class="toggle-vis" data-column="1" type="button" title="Mostrar/ocultar Ente">Ente</button>
                <button class="toggle-vis" data-column="2" type="button" title="Mostrar/ocultar Nº Cliente">Nº Cliente</button>
                <button class="toggle-vis" data-column="3" type="button" title="Mostrar/ocultar Nº CtaDebito">Nº CtaDebito</button>
                <button class="toggle-vis" data-column="4" type="button" title="Mostrar/ocultar Fecha Vto">Fecha Vto</button>
                <button class="toggle-vis" data-column="5" type="button" title="Mostrar/ocultar Cuota">Cuota</button>
                <button class="toggle-vis" data-column="6" type="button" title="Mostrar/ocultar PDF">PDF</button>
                <button class="toggle-vis" data-column="7" type="button" title="Mostrar/ocultar Tipo Comp">Tipo Comp</button>
                <button class="toggle-vis" data-column="10" type="button" title="Mostrar/ocultar Importe USD">Importe USD</button>
                <button class="toggle-vis" data-column="11" type="button" title="Mostrar/ocultar USD Actualizados">USD Actualizados</button>
                <button class="toggle-vis" data-column="12" type="button" title="Mostrar/ocultar Referencia">Referencia</button>
            </div>

            <div class="table-wrap">
                <table id="dataTable" class="display compact" width="100%">
                    <thead>
                        <tr>
                            <th>Nro Transaccion</th>
                            <th>Ente</th>
                            <th>Nº Cliente</th>
                            <th>Nº CtaDebito</th>
                            <th>Fecha Vto</th>
                            <th>Cuota</th>
                            <th>PDF</th>
                            <th>Tipo Comp</th>
                            <th>Fecha Pago</th>
                            <th>Importe $</th>
                            <th>Importe USD</th>
                            <th>USD Actualizados</th>
                            <th>Referencia</th>
                        </tr>
                    </thead>
                    <tbody id="contenTabla"></tbody>
                    <tfoot>
                        <tr>
                            <th>Nro Transaccion</th>
                            <th>Ente</th>
                            <th>Nº Cliente</th>
                            <th>Nº CtaDebito</th>
                            <th>Fecha Vto</th>
                            <th>Cuota</th>
                            <th>PDF</th>
                            <th>Tipo Comp</th>
                            <th>Fecha Pago</th>
                            <th>Importe $</th>
                            <th>Importe USD</th>
                            <th>USD Actualizados</th>
                            <th>Referencia</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </section>
            </div>
    </main>

    <div id="modalFallos" class="modal-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Archivos no procesados">
        <div class="modal-panel">
            <header class="modal-header">
                <h2>PDFs no procesados</h2>
                <button id="modalFallosCerrar" class="modal-close" type="button" aria-label="Cerrar" title="Cerrar ventana">&times;</button>
            </header>
            <div id="modalFallosBody" class="modal-body"></div>
            <footer class="modal-footer">
                <span class="modal-hint">Usá los botones para abrir la carpeta o el PDF</span>
                <button id="modalFallosCerrarBtn" class="btn btn-ghost" type="button" title="Cerrar ventana de fallos">Cerrar</button>
            </footer>
        </div>
    </div>

    <div id="modalDetalle" class="modal-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Detalle de referencia">
        <div class="modal-panel modal-panel-detalle">
            <header class="modal-header">
                <h2 id="detalleTitulo"></h2>
                <button id="modalDetalleCerrar" class="modal-close" type="button" aria-label="Cerrar" title="Cerrar ventana">&times;</button>
            </header>
            <div class="modal-body">
                <div class="detalle-toolbar">
                    <label>
                        <span>Agrupar por</span>
                        <select id="detalleGroupBy">
                            <option value="year">Año</option>
                            <option value="ente">Ente</option>
                        </select>
                    </label>
                </div>
                <div id="detalleTableWrap"></div>
            </div>
            <footer class="modal-footer">
                <button id="modalDetalleCerrarBtn" class="btn btn-ghost" type="button">Cerrar</button>
            </footer>
        </div>
    </div>

    <div id="modalInfoUsd" class="modal-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-label="¿Qué significa USD Actualizados?">
        <div class="modal-panel modal-panel-info">
            <header class="modal-header">
                <h2>💡 ¿Qué significa "USD actualizados"?</h2>
                <button id="modalInfoUsdCerrar" class="modal-close" type="button" aria-label="Cerrar" title="Cerrar ventana">&times;</button>
            </header>
            <div class="modal-body">
                <p>El valor de <strong>USD actualizados</strong> muestra cuánto valdría hoy un pago realizado en el pasado, expresado en dólares.</p>
                <p>Esto se utiliza para tener una referencia más real del poder adquisitivo del dinero a lo largo del tiempo, teniendo en cuenta la inflación en Estados Unidos.</p>

                <h3>📊 ¿Por qué se muestra este valor?</h3>
                <p>Cuando un pago fue realizado hace varios años, su valor en dólares de ese momento no refleja lo mismo que hoy. Por eso, se aplica un ajuste basado en índices de inflación oficiales para actualizarlo a "valor presente".</p>

                <h3>⚙️ ¿Cómo se calcula?</h3>
                <p>El sistema toma el valor original en USD y lo ajusta utilizando la evolución del índice de precios (CPI) mes a mes.</p>
                <p>De forma simplificada:</p>
                <p><strong>USD actualizado = USD original × factor de actualización</strong></p>

                <h3>🧾 Ejemplo simple</h3>
                <p>En 2018 se realizó un pago de: <strong>USD 100</strong><br>Ajustando por inflación hasta hoy, ese mismo pago equivale aproximadamente a: <strong>USD 125 actuales</strong></p>
                <p>👉 Esto no significa que el pago cambie, sino que sirve para entender su valor equivalente en el tiempo.</p>

                <div class="info-nota">
                    <h3>ℹ️ Importante</h3>
                    <ul>
                        <li>Este valor es <strong>informativo</strong> y se utiliza solo como referencia económica.</li>
                        <li>No modifica el monto real del pago realizado.</li>
                        <li>Permite comparar pagos de distintos años en una misma escala de valor actual.</li>
                    </ul>
                </div>
            </div>
            <footer class="modal-footer">
                <button id="modalInfoUsdCerrarBtn" class="btn btn-ghost" type="button">Cerrar</button>
            </footer>
        </div>
    </div>

    @Scripts.Render("~/bundles/appscripts")

</body>
</html>
